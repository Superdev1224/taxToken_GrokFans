# BSC Network (97 = testnet, 56 = mainnet)
NEXT_PUBLIC_BSC_CHAIN_ID=97
NEXT_PUBLIC_GROKFANS_CONTRACT=0x91c0f0D5dB7f63BCC5f20259C1b6EF5ee90d81Ca
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# Optional fallback for SSR & WalletConnect metadata (referral links auto-use the current domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect — get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Supabase (optional — app works offline without it)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
